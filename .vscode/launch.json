{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Calibrate Camera (Astra, index 1)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/Collaborative_Robotics/calibrateCamera.py",
      "args": ["--calibrate", "--camera", "1"],
      "console": "integratedTerminal",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "env": { "PYTHONUTF8": "1", "PYTHONIOENCODING": "utf-8" }
    },
    {
      "name": "Preview Undistort (Astra, index 1)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/Collaborative_Robotics/calibrateCamera.py",
      "args": ["--preview", "--camera", "1"],
      "console": "integratedTerminal",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "env": { "PYTHONUTF8": "1", "PYTHONIOENCODING": "utf-8" }
    }
  ]
}
